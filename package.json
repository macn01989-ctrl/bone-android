{
  "name": "bone-android",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "sync:android": "npm run build && npx cap sync android && npm run restore:good-apk-assets",
    "restore:good-apk-assets": "powershell -ExecutionPolicy Bypass -File tools/restore-good-apk-assets.ps1",
    "sync:android:source": "npm run build && npx cap sync android",
    "build:android:safe": "npm run restore:good-apk-assets -- -SkipDist && cd android && gradlew.bat assembleDebug"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
